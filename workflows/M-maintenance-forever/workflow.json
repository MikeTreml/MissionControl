{
  "code": "M",
  "name": "Maintenance Forever",
  "description": "Continuous Mission Control improvement loop: read plans, implement one bounded task, validate, commit, sleep, repeat.",
  "lanes": ["plan", "develop", "review", "surgery", "done"],
  "steps": [
    { "id": "investigate", "agent": "investigator", "lane": "plan", "outputCode": "i" },
    { "id": "implement", "agent": "developer", "lane": "develop", "outputCode": "d" },
    { "id": "review", "agent": "reviewer", "lane": "review", "outputCode": "r", "qualityGate": { "field": "score", "minimum": 80 } },
    { "id": "polish", "agent": "surgeon", "lane": "surgery", "outputCode": "s", "runWhen": "review.score < 100" }
  ],
  "babysitter": {
    "targetQuality": 85,
    "maxIterations": 3,
    "mode": "sequential",
    "logLevel": "info",
    "stopOnFirstFailure": false
  },
  "humanGates": [],
  "campaign": {
    "iteratesItems": false,
    "perItemMode": "sequential"
  }
}
