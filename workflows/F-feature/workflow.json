{
  "code": "F",
  "name": "Feature",
  "description": "Standard feature development: plan, build, review, polish, approve, ship.",
  "steps": [
    { "id": "plan", "agent": "planner", "lane": "plan", "outputCode": "p", "breakpoint": true, "breakpointReason": "Review plan before implementation." },
    { "id": "build", "agent": "developer", "lane": "develop", "outputCode": "d" },
    { "id": "review", "agent": "reviewer", "lane": "review", "outputCode": "r", "qualityGate": { "field": "score", "minimum": 80 }, "onFail": { "action": "loopBackTo", "target": "plan", "maxCycles": 3 } },
    { "id": "polish", "agent": "surgeon", "lane": "surgery", "outputCode": "s" }
  ],
  "babysitter": {
    "targetQuality": 80,
    "maxIterations": 3,
    "mode": "sequential",
    "logLevel": "info",
    "stopOnFirstFailure": false
  },
  "humanGates": ["plan"],
  "campaign": {
    "iteratesItems": false,
    "perItemMode": "sequential"
  }
}
